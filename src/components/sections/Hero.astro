---
import { basics, work, education, certificates, skills, languages, projects } from "@cv"
import Section from "@/components/Section.astro"
import Mail from "@/icons/Mail.astro"
import Phone from "@/icons/Phone.astro"
import X from "@/icons/X.astro"
import LinkedIn from "@/icons/Linkedin.astro"
import GitHub from "@/icons/Github.astro"
import WorldMap from "@/icons/WorldMap.astro"
import Download from "@/icons/Download.astro"
import type { SocialIcon } from "@/types"

const cvData = JSON.stringify({ basics, work, education, certificates, skills, languages, projects })

const { name, label, image, location, profiles, phone, email } = basics
const { city, region } = location

const SOCIAL_ICONS: SocialIcon = {
	GitHub,
	LinkedIn,
	X,
}

const linkedInfo = profiles.find(({ network }) => network === "LinkedIn")
const linkedUrl = linkedInfo?.url
---

<Section>
	<div class="container">
		<div class="info">
			<h1>{name}</h1>
			<h2>{label}</h2>
			<span>
				<a
					href={`https://www.google.com/maps/search/${encodeURIComponent(`${city}, ${region}`)}`}
					target="_blank"
					rel="noopener noreferrer"
					title={`Ver: ${city}, ${region}`}
					class="location-link"
				>
					<WorldMap />
					{city}, {region}
				</a>
			</span>
			<footer class="print">
				{email} &bull; {phone} &bull; {linkedUrl}
			</footer>
			<footer class="no-print">
				{
					email && (
						<a
							href={`mailto:${email}`}
							title={`Enviar un correo electrónico a ${name} al correo ${email}`}
							target="_blank"
							rel="noopener noreferrer"
						>
							<Mail />
						</a>
					)
				}
				{
					phone && (
						<a
							href={`tel:${phone}`}
							title={`Llamar por teléfono a ${name} al número ${phone}`}
							target="_blank"
							rel="noopener noreferrer"
						>
							<Phone />
						</a>
					)
				}
				{
					profiles.map(({ network, url, username }) => {
						const Icon = SOCIAL_ICONS[network]

						return (
							<a
								href={url}
								title={`Visitar el perfil de ${name} en ${network}`}
								target="_blank"
								rel="noopener noreferrer"
							>
								<Icon />
							</a>
						)
					})
				}
				<button
					id="download-cv-btn"
					title="Descargar CV en formato ATS (PDF)"
					class="download-btn"
					type="button"
				>
					<Download />
					<span class="download-label">CV</span>
				</button>
			</footer>
		</div>
		<figure id="easter-egg-cat" class="easter-egg" data-visible="false">
			<img src={image} alt="🐱 ¡Me encontraste!" />
		</figure>
	</div>
	<div id="cv-data" hidden set:html={cvData}></div>
</Section>

<script>
	import { generateATSPdf } from '@/scripts/generate-ats-pdf';

	// ── PDF Download ──
	const btn = document.getElementById('download-cv-btn');
	btn?.addEventListener('click', () => {
		const label = btn.querySelector('.download-label');
		const originalText = label?.textContent;
		if (label) label.textContent = '...';
		(btn as HTMLButtonElement).disabled = true;

		try {
			const raw = document.getElementById('cv-data')?.textContent || '{}';
			const cvData = JSON.parse(raw);
			generateATSPdf(cvData);
		} catch (err) {
			console.error('Error generating PDF:', err);
			alert('Error al generar el PDF. Revisa la consola.');
		} finally {
			if (label) label.textContent = originalText || 'CV';
			(btn as HTMLButtonElement).disabled = false;
		}
	});

	// ── Easter egg: type "gato" to reveal the cat ──
	(() => {
		let buffer = '';
		const SECRET = 'gato';

		document.addEventListener('keydown', (e) => {
			if (e.key.length !== 1 || e.metaKey || e.ctrlKey || e.altKey) return;

			buffer += e.key.toLowerCase();
			if (buffer.length > 20) buffer = buffer.slice(-20);

			if (buffer.includes(SECRET)) {
				const fig = document.getElementById('easter-egg-cat');
				if (fig) {
					const isVisible = fig.getAttribute('data-visible') === 'true';
					fig.setAttribute('data-visible', isVisible ? 'false' : 'true');
					if (!isVisible) {
						fig.querySelector('img')?.animate([
							{ transform: 'scale(0) rotate(-20deg)', opacity: 0 },
							{ transform: 'scale(1.1) rotate(5deg)', opacity: 1 },
							{ transform: 'scale(1) rotate(0deg)', opacity: 1 }
						], { duration: 500, easing: 'ease-out' });
					}
				}
				buffer = '';
			}
		});
	})();
</script>

<style>
	.container {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.info {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding-right: 32px;
	}

	h1 {
		font-size: 2rem;
	}

	h2 {
		color: var(--color-secondary);
		font-weight: 500;
		font-size: 1.1rem;
		text-wrap: balance;
	}

	/* Easter egg cat — hidden by default */
	.easter-egg[data-visible="false"] {
		display: none !important;
	}

	.easter-egg[data-visible="true"] {
		display: block;
	}

	.easter-egg img {
		aspect-ratio: 1 / 1;
		object-fit: cover;
		width: 128px;
		height: 128px;
		border-radius: 16px;
	}

	span {
		color: var(--color-secondary);
		display: flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.85rem;
		letter-spacing: -0.05rem;
	}

	footer {
		color: var(--color-secondary);
		font-size: 0.65rem;
		display: flex;
		gap: 4px;
		margin-top: 8px;
	}

	footer a,
	footer button {
		color: var(--color-muted);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		padding: 4px;
		height: 32px;
		width: 32px;
		border-radius: 6px;
		transition: background 0.3s ease, border-color 0.3s ease;
		cursor: pointer;
		background: transparent;
	}

	footer a:hover,
	footer button:hover {
		background: var(--color-accent);
		border: 1px solid var(--color-border-hover);
	}

	/* Download button stands out */
	.download-btn {
		width: auto !important;
		gap: 4px;
		padding: 4px 10px !important;
		font-size: 0.7rem;
		font-weight: 600;
		font-family: var(--font-family-sans);
		background: var(--color-primary) !important;
		color: var(--color-bg) !important;
		border-color: var(--color-primary) !important;
	}

	.download-btn:hover {
		opacity: 0.85;
		background: var(--color-primary) !important;
		border-color: var(--color-primary) !important;
	}

	.download-btn:disabled {
		opacity: 0.6;
		cursor: wait;
	}

	.download-label {
		color: inherit;
		font-size: 0.7rem;
		letter-spacing: 0;
	}

	.location-link {
		color: var(--color-subtle);
		display: flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.85rem;
		letter-spacing: -0.05rem;
		text-decoration: none;
	}

	.location-link:hover {
		text-decoration: underline;
	}

	@media (width <= 700px) {
		.container {
			flex-direction: column-reverse;
		}

		.info {
			justify-content: center;
			align-items: center;
			padding-right: 0;
			text-align: center;
		}

		figure {
			display: flex;
			justify-content: center;
			align-items: center;
		}

		h2 {
			text-wrap: balance;
		}

		figure {
			margin: 0 auto;
		}

		.easter-egg img {
			width: 96px;
			height: 96px;
		}
	}

	@media print {
		.container {
			gap: 0.5rem;
		}

		.info {
			gap: 0.2rem;
			padding-right: 8px;
		}

		h1 {
			font-size: 1.4rem;
		}

		h2 {
			font-size: 0.85rem;
		}

		.easter-egg {
			display: none !important;
		}

		.download-btn {
			display: none !important;
		}

		span {
			font-size: 0.7rem;
		}

		footer.print {
			font-size: 0.6rem;
			margin-top: 2px;
		}
	}
</style>